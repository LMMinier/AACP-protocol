{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AACPAuditLog",
  "description": "Schema for AACP detection audit log entries",
  "type": "object",
  "required": ["segment_id", "timestamp", "trust_level", "source_id", "source_type", "blocked", "confidence", "action"],
  "properties": {
    "segment_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "number", "description": "Unix epoch timestamp" },
    "trust_level": { "type": "string", "enum": ["SYSTEM", "USER", "EXTERNAL", "UNTRUSTED"] },
    "source_id": { "type": "string" },
    "source_type": { "type": "string", "enum": ["system", "user", "rag", "tool_result", "memory", "unknown"] },
    "blocked": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 10.0 },
    "action": { "type": "string", "enum": ["ALLOW", "BLOCK", "SANITIZE", "ESCALATE"] },
    "attack_category": { "type": ["string", "null"] },
    "matched_pattern": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "llm_hook_used": { "type": "boolean", "default": false },
    "llm_hook_error": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  }
}
