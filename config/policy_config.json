{
  "version": "0.1.1",
  "default_threshold": 0.65,
  "trust_level_baselines": {
    "SYSTEM": 0.0,
    "USER": 0.0,
    "EXTERNAL": 0.0,
    "UNTRUSTED": 0.20
  },
  "actions": {
    "below_threshold": "ALLOW",
    "above_threshold": "BLOCK",
    "system_trust": "ALLOW"
  },
  "enabled_stages": {
    "normalization": true,
    "structural_markers": true,
    "semantic_keywords": true,
    "base64_scan": true,
    "llm_hook": false
  },
  "llm_hook": {
    "provider": null,
    "model": null,
    "fail_safe": "ALLOW",
    "timeout_seconds": 5
  },
  "audit_log": {
    "enabled": true,
    "schema_version": "0.1.1",
    "output": "stderr"
  }
}
